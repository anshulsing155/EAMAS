<UserControl x:Class="EAMAS.Desktop.Controls.TaskCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:EAMAS.Desktop.Converters"
             xmlns:enums="clr-namespace:EAMAS.Core.Enums;assembly=EAMAS.Core"
             x:Name="Root">
    <UserControl.Resources>
        <conv:PriorityToColorConverter  x:Key="PriorityColor"/>
        <conv:PriorityToLabelConverter  x:Key="PriorityLabel"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:InitialsConverter         x:Key="InitialsConverter"/>
    </UserControl.Resources>

    <Border Background="#1E293B" CornerRadius="8" Margin="0,0,0,8"
            BorderBrush="#334155" BorderThickness="1"
            Cursor="Hand">
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="#3B82F6"/>
                        <Setter Property="Background" Value="#263244"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid Margin="12,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Priority chip + Labels -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6" FlowDirection="LeftToRight">
                <Border CornerRadius="4" Padding="6,2" Margin="0,0,4,0"
                        Background="{Binding Task.Priority, Converter={StaticResource PriorityColor}}">
                    <TextBlock Text="{Binding Task.Priority, Converter={StaticResource PriorityLabel}}"
                               FontSize="10" FontWeight="Bold" Foreground="White"/>
                </Border>
                <ItemsControl ItemsSource="{Binding Task.Labels}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#334155" CornerRadius="4" Padding="5,2" Margin="2,0,0,0">
                                <TextBlock Text="{Binding}" FontSize="10" Foreground="#94A3B8"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <!-- AI badge -->
                <Border Background="#1D4ED8" CornerRadius="4" Padding="5,2" Margin="4,0,0,0"
                        Visibility="{Binding Task.IsAiGenerated, Converter={StaticResource BoolVis}}"
                        ToolTip="AI Generated">
                    <TextBlock Text="AI" FontSize="9" FontWeight="Bold" Foreground="White"/>
                </Border>
            </StackPanel>

            <!-- Row 1: Title -->
            <TextBlock Grid.Row="1" Text="{Binding Task.Title}" FontSize="13" FontWeight="SemiBold"
                       Foreground="White" TextWrapping="Wrap" Margin="0,0,0,6" MaxHeight="42"
                       TextTrimming="CharacterEllipsis"/>

            <!-- Row 2: Description snippet -->
            <TextBlock Grid.Row="2" Text="{Binding Task.AiGeneratedSummary}" FontSize="11"
                       Foreground="#64748B" TextWrapping="Wrap" MaxHeight="34"
                       TextTrimming="CharacterEllipsis" Margin="0,0,0,8"
                       Visibility="{Binding Task.AiGeneratedSummary, Converter={StaticResource BoolVis}}"/>

            <!-- Row 3: Assignee + Hours + Actions -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Assignee avatar -->
                    <Border Width="22" Height="22" CornerRadius="11"
                            Background="#3B82F6" Margin="0,0,6,0"
                            Visibility="{Binding Task.AssignedToUserName, Converter={StaticResource BoolVis}}"
                            ToolTip="{Binding Task.AssignedToUserName}">
                        <TextBlock FontSize="10" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Text="{Binding Task.AssignedToUserName, Converter={StaticResource InitialsConverter}}"/>
                    </Border>
                    <!-- Hours -->
                    <TextBlock Foreground="#64748B" FontSize="11">
                        <Run Text="&#x23F1;"/>
                        <Run Text="{Binding Task.EstimatedHours, StringFormat='{}{0:0.#}h'}"/>
                    </TextBlock>
                    <!-- Due date -->
                    <TextBlock Foreground="#64748B" FontSize="11" Margin="8,0,0,0"
                               Visibility="{Binding Task.DueDate, Converter={StaticResource BoolVis}}"
                               Text="{Binding Task.DueDate, StringFormat='Due {0:MMM d}'}"/>
                </StackPanel>
                <!-- Action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="→" FontSize="13" Width="24" Height="22"
                            Background="Transparent" Foreground="#94A3B8" BorderThickness="0"
                            ToolTip="Move Forward"
                            Command="{Binding DataContext.MoveForwardCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            CommandParameter="{Binding Task}"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
