<UserControl x:Class="EAMAS.Desktop.Controls.ScoreGauge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root" Width="80" Height="80">
    <Grid>
        <!-- Background arc -->
        <Ellipse Width="80" Height="80" Stroke="#334155" StrokeThickness="8" Fill="Transparent"/>
        <!-- Score text -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="{Binding Score, ElementName=Root}" FontSize="22" FontWeight="Bold"
                       Foreground="{Binding ScoreColor, ElementName=Root}" HorizontalAlignment="Center"/>
            <TextBlock Text="/100" FontSize="9" Foreground="#64748B" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
