<UserControl x:Class="EAMAS.Desktop.Controls.TaskCardItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:EAMAS.Desktop.Converters"
             x:Name="Root">
    <UserControl.Resources>
        <conv:PriorityToColorConverter  x:Key="PriorityColor"/>
        <conv:PriorityToLabelConverter  x:Key="PriorityLabel"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:IntToVisibilityConverter  x:Key="IntVis"/>
        <conv:InitialsConverter         x:Key="InitialsConverter"/>
    </UserControl.Resources>

    <Border Background="#1E293B" CornerRadius="8" Margin="0,0,0,8"
            BorderBrush="#334155" BorderThickness="1" Padding="12,10"
            Cursor="Hand">
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="#3B82F6"/>
                        <Setter Property="Background" Value="#263244"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Border.InputBindings>
            <MouseBinding MouseAction="LeftClick"
                          Command="{Binding ViewModel.OpenTaskDetailCommand, ElementName=Root}"
                          CommandParameter="{Binding Task, ElementName=Root}"/>
        </Border.InputBindings>

        <StackPanel>
            <!-- Priority + Labels row -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <Border CornerRadius="4" Padding="5,2" Margin="0,0,4,0"
                        Background="{Binding Task.Priority, ElementName=Root, Converter={StaticResource PriorityColor}}">
                    <TextBlock Text="{Binding Task.Priority, ElementName=Root, Converter={StaticResource PriorityLabel}}"
                               FontSize="9" FontWeight="Bold" Foreground="White"/>
                </Border>
                <Border Background="#334155" CornerRadius="4" Padding="4,2" Margin="0,0,4,0"
                        Visibility="{Binding Task.IsAiGenerated, ElementName=Root, Converter={StaticResource BoolVis}}"
                        ToolTip="AI Generated task">
                    <TextBlock Text="AI" FontSize="9" Foreground="#60A5FA" FontWeight="Bold"/>
                </Border>
                <ItemsControl ItemsSource="{Binding Task.Labels, ElementName=Root}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#0F172A" CornerRadius="3" Padding="4,2" Margin="0,0,2,0">
                                <TextBlock Text="{Binding}" FontSize="9" Foreground="#64748B"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Title -->
            <TextBlock Text="{Binding Task.Title, ElementName=Root}"
                       FontSize="12" FontWeight="SemiBold" Foreground="White"
                       TextWrapping="Wrap" MaxHeight="38" TextTrimming="CharacterEllipsis"
                       Margin="0,0,0,8"/>

            <!-- Footer: assignee + hours + move button -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="20" Height="20" CornerRadius="10" Background="#3B82F6" Margin="0,0,5,0"
                            Visibility="{Binding Task.AssignedToUserName, ElementName=Root, Converter={StaticResource BoolVis}}"
                            ToolTip="{Binding Task.AssignedToUserName, ElementName=Root}">
                        <TextBlock FontSize="9" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Text="{Binding Task.AssignedToUserName, ElementName=Root, Converter={StaticResource InitialsConverter}}"/>
                    </Border>
                    <TextBlock Foreground="#475569" FontSize="11"
                               Text="{Binding Task.EstimatedHours, ElementName=Root, StringFormat='⏱ {0:0.#}h'}"/>
                </StackPanel>
                <Button Grid.Column="1" Content="→" FontSize="13"
                        Width="22" Height="22" Padding="0"
                        Background="#334155" Foreground="#94A3B8"
                        BorderThickness="0"
                        ToolTip="Move to next stage"
                        Command="{Binding ViewModel.MoveForwardCommand, ElementName=Root}"
                        CommandParameter="{Binding Task, ElementName=Root}"
                        Cursor="Hand"/>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
