<Window x:Class="EAMAS.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:EAMAS.Desktop.Converters"
        Title="EAMAS - Login"
        Width="420"
        SizeToContent="Height"
        MinHeight="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F8FAFC"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <conv:NullOrEmptyToVisibilityConverter x:Key="NullToVisConverter"/>
        <conv:BoolToVisibilityConverter        x:Key="BoolVis"/>
        <conv:InverseBoolConverter             x:Key="InverseBoolConverter"/>
    </Window.Resources>

    <!-- Window fade-in on first show -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.3">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <StackPanel>

        <!-- Card — slides up + fades in on load -->
        <Border x:Name="LoginCard"
                Margin="32,28,32,0"
                Background="White" CornerRadius="14"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                Opacity="0">
            <Border.Effect>
                <DropShadowEffect Color="#000" Opacity="0.08" BlurRadius="18"
                                  ShadowDepth="5" Direction="270"/>
            </Border.Effect>
            <Border.RenderTransform>
                <TranslateTransform x:Name="CardSlide" Y="24"/>
            </Border.RenderTransform>
            <Border.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="LoginCard"
                                             Storyboard.TargetProperty="Opacity"
                                             From="0" To="1" Duration="0:0:0.4">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="CardSlide"
                                             Storyboard.TargetProperty="Y"
                                             From="24" To="0" Duration="0:0:0.4">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>

            <StackPanel Margin="28,24">

                <!-- Logo -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Border Width="52" Height="52" CornerRadius="12"
                            Background="{StaticResource PrimaryBrush}"
                            HorizontalAlignment="Center" Margin="0,0,0,10">
                        <TextBlock Text="E" FontSize="26" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="EAMAS" FontSize="20" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Employee Activity Monitoring"
                               FontSize="11" HorizontalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Loading bar -->
                <ProgressBar IsIndeterminate="True" Height="2" Margin="0,0,0,12"
                             Foreground="{StaticResource PrimaryBrush}"
                             Background="Transparent" BorderThickness="0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolVis}}"/>

                <!-- Organisation code -->
                <TextBlock Text="ORGANISATION CODE" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtOrgCode"
                         Style="{StaticResource InputField}"
                         Text="{Binding OrganizationCode, UpdateSourceTrigger=PropertyChanged}"
                         CharacterCasing="Upper"
                         ToolTip="SuperAdmin uses: SYSTEM"
                         Margin="0,0,0,12"/>

                <!-- Username -->
                <TextBlock Text="USERNAME" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtUsername"
                         Style="{StaticResource InputField}"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12"/>

                <!-- Password -->
                <TextBlock Text="PASSWORD" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                <PasswordBox x:Name="TxtPassword"
                             Style="{StaticResource PasswordField}"
                             Margin="0,0,0,8"/>

                <!-- Error message -->
                <Border Background="{StaticResource ErrorBgBrush}"
                        BorderBrush="{StaticResource ErrorBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="10,6" Margin="0,0,0,10"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource ErrorBrush}"
                               FontSize="12" TextWrapping="Wrap"/>
                </Border>

                <!-- Sign In button -->
                <Button Content="Sign In"
                        Style="{StaticResource PrimaryButton}"
                        Height="40" FontSize="14" FontWeight="SemiBold"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                        Click="LoginButton_Click"
                        Margin="0,4,0,0"/>

                <TextBlock FontSize="11" HorizontalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextAlignment="Center" TextWrapping="Wrap"
                           Margin="0,12,0,0"
                           Text="Enter your organisation code, username and password."/>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <TextBlock Text="© 2026 EAMAS — Employee Activity Monitoring and Analytics System"
                   FontSize="10" HorizontalAlignment="Center"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   Margin="0,10,0,14"/>
    </StackPanel>
</Window>
