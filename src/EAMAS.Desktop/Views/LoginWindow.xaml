<Window x:Class="EAMAS.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:EAMAS.Desktop.Converters"
        Title="EAMAS — Login" Height="600" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F8FAFC">

    <Window.Resources>
        <conv:NullOrEmptyToVisibilityConverter x:Key="NullToVisConverter"/>
        <conv:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Main Login Card -->
        <Border Margin="36" VerticalAlignment="Center"
                Background="White" CornerRadius="12"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="16" ShadowDepth="4" Direction="270"/>
            </Border.Effect>

            <StackPanel Margin="32,28">
                <!-- Logo + Title -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,24">
                    <Border Width="52" Height="52" CornerRadius="12"
                            Background="{StaticResource PrimaryBrush}"
                            HorizontalAlignment="Center" Margin="0,0,0,12">
                        <TextBlock Text="E" FontSize="26" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="EAMAS" FontSize="20" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Employee Activity Monitoring"
                               FontSize="11" HorizontalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Organisation Code -->
                <TextBlock Text="ORGANISATION CODE" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="TxtOrgCode"
                         Style="{StaticResource InputField}"
                         Text="{Binding OrganizationCode, UpdateSourceTrigger=PropertyChanged}"
                         CharacterCasing="Upper"
                         ToolTip="Enter your organisation code (e.g. ACME). SuperAdmin uses: SYSTEM"
                         Margin="0,0,0,14"/>

                <!-- Username -->
                <TextBlock Text="USERNAME" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="TxtUsername"
                         Style="{StaticResource InputField}"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,14"/>

                <!-- Password -->
                <TextBlock Text="PASSWORD" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,5"/>
                <PasswordBox x:Name="TxtPassword"
                             Style="{StaticResource PasswordField}"
                             Margin="0,0,0,6"/>

                <!-- Error Message -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource ErrorBrush}"
                           FontSize="12" TextWrapping="Wrap"
                           Margin="0,0,0,12"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisConverter}}"/>

                <!-- Sign In Button -->
                <Button Content="Sign In"
                        Style="{StaticResource PrimaryButton}"
                        Height="40" FontSize="14"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                        Click="LoginButton_Click"
                        Margin="0,4,0,0"/>

                <!-- Hint -->
                <TextBlock FontSize="11" HorizontalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextAlignment="Center"
                           Margin="0,14,0,0">
                    <Run Text="SuperAdmin — Org: "/>
                    <Run Text="SYSTEM" FontWeight="SemiBold"/>
                    <Run Text=" / User: "/>
                    <Run Text="superadmin" FontWeight="SemiBold"/>
                    <Run Text=" / Pass: "/>
                    <Run Text="Admin@123" FontWeight="SemiBold"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <TextBlock Grid.Row="1"
                   Text="© 2025 EAMAS — Employee Activity Monitoring &amp; Analytics System"
                   FontSize="10" HorizontalAlignment="Center"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   Margin="0,0,0,10"/>
    </Grid>
</Window>
