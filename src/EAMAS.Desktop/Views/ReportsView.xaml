<UserControl x:Class="EAMAS.Desktop.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:EAMAS.Desktop.Converters"
             xmlns:ctrl="clr-namespace:EAMAS.Desktop.Controls"
             xmlns:local="clr-namespace:EAMAS.Desktop.Views"
             Background="{StaticResource ContentBgBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:ScoreToColorConverter x:Key="ScoreColor"/>
        <conv:ScoreToProgressBrushConverter x:Key="ScoreProgressBrush"/>
        <local:IndexToBoolConverter x:Key="IndexToBoolConv"/>
        <local:ScoreTextColorConverter x:Key="ScoreTextColorConv"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24">
            <!-- Header -->
            <Grid Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Reports &amp; Analytics" Style="{StaticResource HeadingLarge}"/>
                    <TextBlock Text="{Binding SummaryLabel}" Style="{StaticResource SecondaryText}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Content="&#xE8C8;  Export CSV" Style="{StaticResource SecondaryButton}"
                        Command="{Binding ExportCsvCommand}"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
            </Grid>

            <!-- Controls -->
            <Border Style="{StaticResource Card}" Padding="16,12" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <RadioButton Content="Today" Margin="0,0,12,0" FontSize="13"
                                     IsChecked="{Binding ReportTypeIndex,
                                         Converter={StaticResource IndexToBoolConv}, ConverterParameter=0}"/>
                        <RadioButton Content="Last 7 Days" Margin="0,0,12,0" FontSize="13"
                                     IsChecked="{Binding ReportTypeIndex,
                                         Converter={StaticResource IndexToBoolConv}, ConverterParameter=1}"/>
                        <RadioButton Content="This Month" Margin="0,0,12,0" FontSize="13"
                                     IsChecked="{Binding ReportTypeIndex,
                                         Converter={StaticResource IndexToBoolConv}, ConverterParameter=2}"/>
                        <RadioButton Content="Custom" Margin="0,0,8,0" FontSize="13"
                                     IsChecked="{Binding ReportTypeIndex,
                                         Converter={StaticResource IndexToBoolConv}, ConverterParameter=3}"/>
                    </StackPanel>

                    <!-- Custom date range -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0">
                        <DatePicker SelectedDate="{Binding CustomFrom}" Width="120"
                                    FontSize="13" Margin="0,0,4,0"/>
                        <TextBlock Text="to" VerticalAlignment="Center" Margin="4,0" Style="{StaticResource SecondaryText}"/>
                        <DatePicker SelectedDate="{Binding CustomTo}" Width="120" FontSize="13"/>
                    </StackPanel>

                    <!-- User selector -->
                    <ComboBox Grid.Column="3" Style="{StaticResource StyledComboBox}"
                              ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}"
                              DisplayMemberPath="FullName" Width="180"
                              Visibility="{Binding IsManager, Converter={StaticResource BoolVis}}"/>
                </Grid>
            </Border>

            <!-- Summary KPIs -->
            <UniformGrid Rows="1" Columns="3" Margin="0,0,0,20">
                <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="TOTAL ACTIVE TIME" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TotalActiveTime}" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="4,0,4,0">
                    <StackPanel>
                        <TextBlock Text="AVG PRODUCTIVITY SCORE" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock FontSize="22" FontWeight="Bold"
                                   Foreground="{Binding AvgScore, Converter={StaticResource ScoreColor}}">
                            <Run Text="{Binding AvgScore, Mode=OneWay}"/>
                            <Run Text="%"/>
                        </TextBlock>
                        <ProgressBar Value="{Binding AvgScore}" Maximum="100"
                                     Style="{StaticResource StyledProgressBar}"
                                     Foreground="{Binding AvgScore, Converter={StaticResource ScoreProgressBrush}}"
                                     Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="REPORT PERIOD" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding SummaryLabel}" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Charts Row -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Productivity Trend -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Daily Productivity Score" Style="{StaticResource HeadingMedium}"
                                   FontSize="15" Margin="0,0,0,16"/>
                        <ctrl:SimpleBarChart Items="{Binding TrendChart}" Height="150" MaxHeightBar="120"/>
                    </StackPanel>
                </Border>

                <!-- Top Apps -->
                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Top Applications" Style="{StaticResource HeadingMedium}"
                                   FontSize="15" Margin="0,0,0,16"/>
                        <ctrl:SimpleBarChart Items="{Binding TopAppsChart}" Height="150" MaxHeightBar="120"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Daily Summary Table -->
            <Border Style="{StaticResource Card}" Padding="0">
                <StackPanel>
                    <StackPanel Margin="20,16,20,12">
                        <TextBlock Text="Daily Breakdown" Style="{StaticResource HeadingMedium}" FontSize="15"/>
                    </StackPanel>
                    <DataGrid Style="{StaticResource StyledDataGrid}"
                              ItemsSource="{Binding Rows}" MaxHeight="340">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="DATE" Binding="{Binding Date}" Width="120"/>
                            <DataGridTextColumn Header="ACTIVE TIME" Binding="{Binding ActiveTime}" Width="100"/>
                            <DataGridTextColumn Header="IDLE TIME" Binding="{Binding IdleTime}" Width="100"/>
                            <DataGridTextColumn Header="PRODUCTIVE" Binding="{Binding ProductiveTime}" Width="100"/>
                            <DataGridTextColumn Header="DISTRACTING" Binding="{Binding DistractingTime}" Width="100"/>
                            <DataGridTemplateColumn Header="SCORE" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="12,4" Orientation="Horizontal">
                                            <TextBlock FontWeight="SemiBold" Width="36">
                                                <Run Text="{Binding Score, Mode=OneWay}"/>
                                                <Run Text="%"/>
                                                <TextBlock.Foreground>
                                                    <SolidColorBrush Color="{Binding Score,
                                                        Converter={StaticResource ScoreTextColorConv}}"/>
                                                </TextBlock.Foreground>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="SCREENSHOTS" Binding="{Binding Screenshots}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
