<UserControl x:Class="EAMAS.Desktop.Views.OrganizationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:EAMAS.Desktop.Converters"
             Background="{StaticResource ContentBgBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVisInverse" Invert="True"/>
        <conv:NullOrEmptyToVisibilityConverter x:Key="MsgVis"/>
        <conv:InverseBoolConverter x:Key="InvBool"/>
    </UserControl.Resources>

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="390"/>
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Organisations" Style="{StaticResource HeadingLarge}"/>
                <TextBlock Text="Manage tenant organisations and their users"
                           Style="{StaticResource SecondaryText}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Content="&#xE710;  Add Organisation" Style="{StaticResource PrimaryButton}"
                    Command="{Binding AddNewCommand}"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
        </Grid>

        <!-- Loading indicator -->
        <ProgressBar Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                     IsIndeterminate="True" Height="3" VerticalAlignment="Top"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolVis}}"
                     Margin="0,0,0,8"/>

        <!-- Org list -->
        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Card}"
                Padding="0" Margin="0,0,12,0">
            <DataGrid ItemsSource="{Binding Organizations}"
                      SelectedItem="{Binding SelectedOrg}"
                      Style="{StaticResource StyledDataGrid}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="CODE" Binding="{Binding Code}"
                                        Width="80" FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="*"/>
                    <DataGridTemplateColumn Header="STATUS" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left"
                                        Background="{Binding StatusColor}" Margin="4,2">
                                    <TextBlock Text="{Binding StatusLabel}" Foreground="White"
                                               FontSize="10" FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="CREATED" Binding="{Binding CreatedLabel}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Right panel: org edit + user management -->
        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}" Padding="0"
                Visibility="{Binding IsEditPanelOpen, Converter={StaticResource BoolVis}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16,20,16">
                <StackPanel>

                    <!-- ══ Organisation section ══════════════════════════ -->
                    <TextBlock Text="{Binding EditPanelTitle}" Style="{StaticResource HeadingMedium}"
                               FontSize="14" Margin="0,0,0,14"/>

                    <!-- Org status message -->
                    <Border Background="#FEF3C7" BorderBrush="#D97706" BorderThickness="1"
                            CornerRadius="6" Padding="10,7" Margin="0,0,0,12"
                            Visibility="{Binding StatusMessage, Converter={StaticResource MsgVis}}">
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#92400E"
                                   FontSize="12" TextWrapping="Wrap"/>
                    </Border>

                    <TextBlock Text="ORGANISATION NAME" Style="{StaticResource SecondaryText}"
                               FontSize="10" Margin="0,0,0,5"/>
                    <TextBox Style="{StaticResource InputField}"
                             Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="ORGANISATION CODE" Style="{StaticResource SecondaryText}"
                               FontSize="10" Margin="0,0,0,5"/>
                    <TextBox Style="{StaticResource InputField}"
                             Text="{Binding EditCode, UpdateSourceTrigger=PropertyChanged}"
                             CharacterCasing="Upper" IsEnabled="{Binding IsNewOrg}"
                             Margin="0,0,0,4"/>
                    <TextBlock Text="Code cannot be changed after creation."
                               Style="{StaticResource SecondaryText}" FontSize="10" Margin="0,0,0,12"
                               Visibility="{Binding IsNewOrg, Converter={StaticResource BoolVisInverse}}"/>
                    <Rectangle Height="0" Margin="0,0,0,12"
                               Visibility="{Binding IsNewOrg, Converter={StaticResource BoolVis}}"/>

                    <TextBlock Text="DESCRIPTION" Style="{StaticResource SecondaryText}"
                               FontSize="10" Margin="0,0,0,5"/>
                    <TextBox Style="{StaticResource InputField}"
                             Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}"
                             Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto" Margin="0,0,0,14"/>

                    <!-- Org action buttons -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="&#xE74D;  Deactivate"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding DeactivateCommand}" HorizontalAlignment="Left"
                                Visibility="{Binding IsNewOrg, Converter={StaticResource BoolVisInverse}}"/>
                        <Button Grid.Column="1" Content="Cancel" Style="{StaticResource SecondaryButton}"
                                Command="{Binding CancelCommand}" Margin="0,0,8,0"/>
                        <Button Grid.Column="2" Content="Save" Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveCommand}"/>
                    </Grid>

                    <!-- ══ Users section (existing orgs only) ════════════ -->
                    <StackPanel Visibility="{Binding ShowUsersPanel, Converter={StaticResource BoolVis}}">
                        <Separator Background="#1E293B" Margin="0,18,0,16"/>

                        <!-- Users header -->
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="{Binding UsersHeaderTitle}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#F1F5F9" VerticalAlignment="Center"/>
                            <Button Content="&#xE710;  Add" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding AddUserCommand}"
                                    HorizontalAlignment="Right" Padding="10,5" FontSize="11"/>
                        </Grid>

                        <!-- User status message -->
                        <Border Background="#FEF3C7" BorderBrush="#D97706" BorderThickness="1"
                                CornerRadius="6" Padding="10,7" Margin="0,0,0,10"
                                Visibility="{Binding UserStatusMessage, Converter={StaticResource MsgVis}}">
                            <TextBlock Text="{Binding UserStatusMessage}" Foreground="#92400E"
                                       FontSize="12" TextWrapping="Wrap"/>
                        </Border>

                        <!-- User list (shown when not editing a user) -->
                        <Border CornerRadius="6" BorderBrush="#1E293B" BorderThickness="1"
                                Background="#0F172A"
                                Visibility="{Binding IsUserEditOpen, Converter={StaticResource BoolVisInverse}}">
                            <ListView ItemsSource="{Binding OrgUsers}"
                                      SelectedItem="{Binding SelectedUser}"
                                      MaxHeight="240" Background="Transparent" BorderThickness="0"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="12,8"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListViewItem">
                                                    <Border x:Name="Bd" Background="Transparent"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#1E293B"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#2563EB"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding FullName}" FontSize="12"
                                                           FontWeight="SemiBold" Foreground="#F1F5F9"/>
                                                <TextBlock Text="{Binding Username}" FontSize="10"
                                                           Foreground="#64748B"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Role}"
                                                       FontSize="10" Foreground="#94A3B8"
                                                       VerticalAlignment="Center" Margin="8,0,4,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>

                        <!-- User edit form (shown when editing a user) -->
                        <StackPanel Visibility="{Binding IsUserEditOpen, Converter={StaticResource BoolVis}}">
                            <TextBlock Text="{Binding UserEditTitle}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#F1F5F9" Margin="0,0,0,12"/>

                            <TextBlock Text="FULL NAME *" Style="{StaticResource SecondaryText}"
                                       FontSize="10" Margin="0,0,0,5"/>
                            <TextBox Style="{StaticResource InputField}"
                                     Text="{Binding UserEditFullName, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,10"/>

                            <TextBlock Text="USERNAME *" Style="{StaticResource SecondaryText}"
                                       FontSize="10" Margin="0,0,0,5"/>
                            <TextBox Style="{StaticResource InputField}"
                                     Text="{Binding UserEditUsername, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsNewUser}" Margin="0,0,0,10"/>

                            <TextBlock Text="EMAIL" Style="{StaticResource SecondaryText}"
                                       FontSize="10" Margin="0,0,0,5"/>
                            <TextBox Style="{StaticResource InputField}"
                                     Text="{Binding UserEditEmail, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,10"/>

                            <TextBlock Text="DEPARTMENT" Style="{StaticResource SecondaryText}"
                                       FontSize="10" Margin="0,0,0,5"/>
                            <TextBox Style="{StaticResource InputField}"
                                     Text="{Binding UserEditDepartment, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,10"/>

                            <TextBlock Text="ORGANISATION" Style="{StaticResource SecondaryText}"
                                       FontSize="10" Margin="0,0,0,5"/>
                            <ComboBox Style="{StaticResource StyledComboBox}"
                                      ItemsSource="{Binding AllOrganizations}"
                                      SelectedItem="{Binding UserEditOrg}"
                                      DisplayMemberPath="DisplayName"
                                      Margin="0,0,0,10"/>

                            <TextBlock Text="ROLE" Style="{StaticResource SecondaryText}"
                                       FontSize="10" Margin="0,0,0,5"/>
                            <ComboBox Style="{StaticResource StyledComboBox}"
                                      ItemsSource="{Binding UserRoleOptions}"
                                      SelectedItem="{Binding UserEditRoleString}"
                                      Margin="0,0,0,10"/>

                            <TextBlock Style="{StaticResource SecondaryText}" FontSize="10" Margin="0,0,0,5">
                                <Run Text="PASSWORD"/>
                                <Run Text=" (leave blank to keep)" Foreground="#94A3B8"/>
                            </TextBlock>
                            <PasswordBox x:Name="TxtUserPwd" Style="{StaticResource PasswordField}"
                                         Margin="0,0,0,14"/>

                            <!-- User form buttons -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="Deactivate"
                                        Style="{StaticResource DangerButton}"
                                        Command="{Binding DeactivateUserCommand}"
                                        HorizontalAlignment="Left"
                                        Visibility="{Binding IsNewUser, Converter={StaticResource BoolVisInverse}}"/>
                                <Button Grid.Column="1" Content="Cancel"
                                        Style="{StaticResource SecondaryButton}"
                                        Command="{Binding CancelUserCommand}" Margin="0,0,8,0"/>
                                <Button Grid.Column="2" Content="Save"
                                        Style="{StaticResource PrimaryButton}"
                                        Click="SaveUser_Click"/>
                            </Grid>
                        </StackPanel>

                    </StackPanel>
                    <!-- end users section -->

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
