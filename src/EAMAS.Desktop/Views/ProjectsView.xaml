<UserControl x:Class="EAMAS.Desktop.Views.ProjectsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:EAMAS.Desktop.Converters"
             xmlns:enums="clr-namespace:EAMAS.Core.Enums;assembly=EAMAS.Core"
             Background="{StaticResource ContentBgBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVisInv" Invert="True"/>
        <conv:StatusMessageColorConverter x:Key="StatusMsgColor"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Left: Project List ─────────────────────────────────── -->
        <Border Grid.Column="0" Background="#0F172A" BorderBrush="#1E293B" BorderThickness="0,0,1,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="#1E293B" Padding="14,12">
                    <Grid>
                        <TextBlock Text="Projects" Style="{StaticResource HeadingSmall}" Foreground="White"/>
                        <Button Content="+ New" HorizontalAlignment="Right"
                                Style="{StaticResource PrimaryButton}" FontSize="11"
                                Command="{Binding NewProjectCommand}" Height="26"/>
                    </Grid>
                </Border>
                <ListBox ItemsSource="{Binding Projects}"
                         SelectedItem="{Binding SelectedProject}"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="12,10">
                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="White" TextTrimming="CharacterEllipsis"/>
                                <TextBlock FontSize="11" Foreground="#64748B" Margin="0,2,0,0">
                                    <Run Text="{Binding GitHubRepoOwner}"/>
                                    <Run Text="/"/>
                                    <Run Text="{Binding GitHubRepoName}"/>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#1E3A5F"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1E293B"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ── Right: Project Form ────────────────────────────────── -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="28,24">

                <!-- Header -->
                <Grid Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="{Binding Name, FallbackValue='New Project'}"
                                   Style="{StaticResource HeadingLarge}"/>
                        <TextBlock Text="Configure GitHub repository and AI integration"
                                   Style="{StaticResource SecondaryText}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <Button Content="Poll Now" Style="{StaticResource SecondaryButton}"
                                Command="{Binding PollNowCommand}" Margin="0,0,8,0"
                                Visibility="{Binding IsNew, Converter={StaticResource BoolVisInv}}"/>
                        <Button Content="Delete" Style="{StaticResource DangerButton}"
                                Command="{Binding DeleteProjectCommand}" Margin="0,0,8,0"
                                Visibility="{Binding IsNew, Converter={StaticResource BoolVisInv}}"/>
                        <Button Content="Save Project" Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </Grid>

                <!-- Status banner (dynamic color) -->
                <Border CornerRadius="8" Padding="14,10" Margin="0,0,0,4"
                        Background="{Binding StatusMessage, Converter={StaticResource StatusMsgColor}}"
                        Visibility="{Binding StatusMessage, Converter={StaticResource BoolVis}}">
                    <Grid>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontSize="13"/>
                        <ProgressBar IsIndeterminate="True" Height="2" VerticalAlignment="Bottom"
                                     Foreground="#60A5FA" Background="Transparent"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}"/>
                    </Grid>
                </Border>

                <!-- Section: Basic Info -->
                <TextBlock Text="Basic Information" FontSize="14" FontWeight="SemiBold"
                           Foreground="White" Margin="0,0,0,12"/>
                <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Project Name" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>
                        <TextBlock Text="Description" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}" Height="60"
                                 TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </Border>

                <!-- Section: GitHub -->
                <TextBlock Text="GitHub Configuration" FontSize="14" FontWeight="SemiBold"
                           Foreground="White" Margin="0,0,0,12"/>
                <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Repository Owner" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding RepoOwner, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Repository Name" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding RepoName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Personal Access Token" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                <PasswordBox x:Name="GhTokenBox" Style="{StaticResource ModernPasswordBox}"
                                             PasswordChanged="GhTokenBox_PasswordChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                <Button Content="Test Connection" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding TestGitHubCommand}" Height="36"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel>
                            <TextBlock Text="Default Branch" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding DefaultBranch, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}" Width="120" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Section: AI -->
                <TextBlock Text="AI Configuration" FontSize="14" FontWeight="SemiBold"
                           Foreground="White" Margin="0,0,0,12"/>
                <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="AI Provider" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding AllProviders}"
                                          SelectedItem="{Binding AiProvider}"
                                          Style="{StaticResource ModernComboBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Model" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding AiModels}"
                                          SelectedItem="{Binding AiModel}"
                                          Style="{StaticResource ModernComboBox}"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="API Key" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                <PasswordBox x:Name="AiKeyBox" Style="{StaticResource ModernPasswordBox}"
                                             PasswordChanged="AiKeyBox_PasswordChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                <Button Content="Test Key" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding TestAiKeyCommand}" Height="36"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel>
                            <TextBlock Text="Temperature" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="64"/>
                                </Grid.ColumnDefinitions>
                                <Slider Grid.Column="0" Minimum="0.1" Maximum="1.0" SmallChange="0.05"
                                        Value="{Binding AiTemperature}" VerticalAlignment="Center"/>
                                <Border Grid.Column="2" Background="#1E293B" CornerRadius="6"
                                        BorderBrush="#334155" BorderThickness="1">
                                    <TextBlock Text="{Binding AiTemperature, StringFormat='{}{0:0.00}'}"
                                               Foreground="#60A5FA" FontSize="13" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Padding="0,6"/>
                                </Border>
                            </Grid>
                            <TextBlock Margin="0,4,0,0" FontSize="10" Foreground="#475569">
                                <Run Text="Lower = more focused  ·  Higher = more creative"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Section: Project Context -->
                <Grid Margin="0,0,0,12">
                    <TextBlock Text="Project Context (Knowledge Base)" FontSize="14" FontWeight="SemiBold"
                               Foreground="White"/>
                    <Button Content="Re-index Knowledge Base" HorizontalAlignment="Right"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding IndexKnowledgeBaseCommand}"/>
                </Grid>
                <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="PRD / Requirements" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding PrdContent, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}" Height="120"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto" Margin="0,0,0,12"/>
                        <TextBlock Text="Architecture Notes" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding ArchitectureNotes, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}" Height="80"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto" Margin="0,0,0,12"/>
                        <TextBlock Text="Tech Stack" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding TechStack, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>
                </Border>

                <!-- Section: Sprint Config -->
                <TextBlock Text="Sprint &amp; QA Configuration" FontSize="14" FontWeight="SemiBold"
                           Foreground="White" Margin="0,0,0,12"/>
                <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Sprint Duration (days)" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding SprintDays}" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Work Hours per Day" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding WorkHoursPerDay}" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="QA Commands (semicolon-separated)" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding QaCommands, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>
                </Border>

                <!-- Generate Tasks -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,40">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Generate Tasks from PRD" FontSize="14" FontWeight="SemiBold"
                                       Foreground="White" Margin="0,0,0,4"/>
                            <TextBlock Text="AI will analyze your PRD and create developer tasks in the Kanban backlog."
                                       Style="{StaticResource SecondaryText}"/>
                        </StackPanel>
                        <Button Content="Generate AI Tasks" HorizontalAlignment="Right"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding GenerateTasksCommand}"
                                VerticalAlignment="Center"/>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
