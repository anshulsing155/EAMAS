<UserControl x:Class="EAMAS.Desktop.Views.ScreenshotsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:EAMAS.Desktop.Converters"
             xmlns:local="clr-namespace:EAMAS.Desktop.Views"
             Background="{StaticResource ContentBgBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:NullToVisibilityConverter x:Key="NullVis"/>
        <conv:NullToVisibilityInverseConverter x:Key="NullVisInverse"/>
        <local:SelectedBorderConverter x:Key="SelectedBorderConv"/>
    </UserControl.Resources>

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Screenshots" Style="{StaticResource HeadingLarge}"/>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Style="{StaticResource SecondaryText}">
                        <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                        <Run Text=" screenshots"/>
                    </TextBlock>
                    <TextBlock Text=" · " Style="{StaticResource SecondaryText}"/>
                    <TextBlock Style="{StaticResource SecondaryText}">
                        <Run Text="Storage used: "/>
                        <Run Text="{Binding StorageLabel, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </StackPanel>

            <!-- Capture + Delete — hidden for Employee role -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Visibility="{Binding CanModify, Converter={StaticResource BoolVis}}">
                <Button Content="&#xE722;  Capture Now" Style="{StaticResource PrimaryButton}"
                        Command="{Binding TakeScreenshotCommand}" Margin="0,0,8,0"/>
                <Button Content="&#xE74D;  Delete" Style="{StaticResource DangerButton}"
                        Command="{Binding DeleteScreenshotCommand}"
                        Visibility="{Binding SelectedScreenshot, Converter={StaticResource NullVis}}"/>
            </StackPanel>
        </Grid>

        <!-- Toolbar -->
        <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource Card}"
                Padding="16,12" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="&#x276E;" Style="{StaticResource SecondaryButton}"
                        Command="{Binding PreviousDayCommand}" Width="36" Padding="0"/>
                <DatePicker Grid.Column="1" SelectedDate="{Binding SelectedDate}"
                            Margin="4,0" Width="130" FontSize="13"/>
                <Button Grid.Column="2" Content="&#x276F;" Style="{StaticResource SecondaryButton}"
                        Command="{Binding NextDayCommand}" Width="36" Padding="0" Margin="4,0,0,0"/>
                <!-- User selector — Managers and above only -->
                <ComboBox Grid.Column="4" Style="{StaticResource StyledComboBox}"
                          ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}"
                          DisplayMemberPath="FullName" Width="180"
                          Visibility="{Binding IsManager, Converter={StaticResource BoolVis}}"/>
            </Grid>
        </Border>

        <!-- Loading overlay -->
        <ProgressBar Grid.Row="2" Grid.ColumnSpan="2" IsIndeterminate="True" Height="3"
                     VerticalAlignment="Top"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolVis}}"/>

        <!-- Screenshot Gallery -->
        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource Card}" Padding="12" Margin="0,0,12,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Screenshots}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="180" Height="140" Margin="6" CornerRadius="8"
                                    Cursor="Hand" BorderThickness="2">
                                <Border.BorderBrush>
                                    <MultiBinding Converter="{StaticResource SelectedBorderConv}">
                                        <Binding Path="."/>
                                        <Binding Path="DataContext.SelectedScreenshot"
                                                 RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                    </MultiBinding>
                                </Border.BorderBrush>
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.SelectCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <Grid>
                                    <!-- Thumbnail loaded from in-DB bytes via BitmapImage -->
                                    <Image Source="{Binding ThumbnailSource}" Stretch="UniformToFill"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>

                                    <!-- Placeholder when no thumbnail yet -->
                                    <Border Background="#1E293B" CornerRadius="6"
                                            Visibility="{Binding ThumbnailSource, Converter={StaticResource NullVisInverse}}">
                                        <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="32" Foreground="#475569"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <Border Background="#CC000000" CornerRadius="0,0,6,6"
                                            VerticalAlignment="Bottom" Padding="8,4">
                                        <StackPanel>
                                            <TextBlock Text="{Binding TimeLabel}" Foreground="White"
                                                       FontSize="11" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding AppName}" Foreground="#CBD5E1"
                                                       FontSize="10" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- Manual capture badge -->
                                    <Border Visibility="{Binding IsManual, Converter={StaticResource BoolVis}}"
                                            Background="{StaticResource PrimaryBrush}" CornerRadius="4"
                                            Padding="4,2" Margin="6" VerticalAlignment="Top" HorizontalAlignment="Right">
                                        <TextBlock Text="Manual" Foreground="White" FontSize="9"/>
                                    </Border>

                                    <!-- Privacy blur badge — shown top-left when image was blurred -->
                                    <Border Visibility="{Binding IsPrivacyBlurred, Converter={StaticResource BoolVis}}"
                                            Background="#B45309" CornerRadius="4"
                                            Padding="5,2" Margin="6" VerticalAlignment="Top" HorizontalAlignment="Left"
                                            ToolTip="{Binding BlurTooltip}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="9" Foreground="White" Margin="0,0,3,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding BlurBadgeLabel}" Foreground="White" FontSize="9"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Preview Panel -->
        <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource Card}"
                Visibility="{Binding SelectedScreenshot, Converter={StaticResource NullVis}}">
            <StackPanel>
                <TextBlock Text="Preview" Style="{StaticResource HeadingMedium}"
                           FontSize="14" Margin="0,0,0,12"/>

                <!-- Loading preview indicator -->
                <ProgressBar IsIndeterminate="True" Height="3" Margin="0,0,0,8"
                             Visibility="{Binding IsLoadingPreview, Converter={StaticResource BoolVis}}"/>

                <Border CornerRadius="6" ClipToBounds="True" Height="160" Background="#F1F5F9">
                    <!-- Full-resolution image downloaded from GridFS -->
                    <Image Source="{Binding SelectedImageSource}" Stretch="Uniform"/>
                </Border>

                <StackPanel Margin="0,12,0,0">
                    <TextBlock Text="TIME" Style="{StaticResource SecondaryText}" FontSize="10" Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding SelectedScreenshot.TimeLabel}" Style="{StaticResource BodyText}"/>
                    <TextBlock Text="APPLICATION" Style="{StaticResource SecondaryText}"
                               FontSize="10" Margin="0,8,0,2"/>
                    <TextBlock Text="{Binding SelectedScreenshot.AppName}" Style="{StaticResource BodyText}"/>
                    <TextBlock Text="FILE SIZE" Style="{StaticResource SecondaryText}"
                               FontSize="10" Margin="0,8,0,2"/>
                    <TextBlock Text="{Binding SelectedScreenshot.SizeLabel}" Style="{StaticResource BodyText}"/>

                    <!-- Privacy blur notice shown when the image was processed -->
                    <Border Visibility="{Binding SelectedIsBlurred, Converter={StaticResource BoolVis}}"
                            Background="#FEF3C7" CornerRadius="6" Padding="10,8" Margin="0,12,0,0"
                            BorderBrush="#F59E0B" BorderThickness="1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="12" Foreground="#B45309" Margin="0,0,6,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Privacy Protected" FontWeight="SemiBold"
                                           Foreground="#92400E" FontSize="11"/>
                            </StackPanel>
                            <TextBlock Text="{Binding SelectedScreenshot.BlurTooltip}"
                                       Foreground="#78350F" FontSize="10" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Button Content="&#xE8A7;  Open Full Size" Style="{StaticResource SecondaryButton}"
                        Command="{Binding OpenScreenshotCommand}" Margin="0,16,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
