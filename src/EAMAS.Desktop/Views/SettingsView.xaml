<UserControl x:Class="EAMAS.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:EAMAS.Desktop.Converters"
             Background="{StaticResource ContentBgBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVisInverse" Invert="True"/>
        <conv:NullOrEmptyToVisibilityConverter x:Key="MsgVis"/>
        <conv:InverseBoolConverter x:Key="InvBool"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24" MaxWidth="760">
            <!-- Header -->
            <StackPanel Margin="0,0,0,24">
                <TextBlock Text="Settings" Style="{StaticResource HeadingLarge}"/>
                <TextBlock Text="Configure monitoring, screenshots, and alerts"
                           Style="{StaticResource SecondaryText}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Status message -->
            <Border Background="#DCFCE7" BorderBrush="#16A34A" BorderThickness="1"
                    CornerRadius="6" Padding="12,8" Margin="0,0,0,16"
                    Visibility="{Binding StatusMessage, Converter={StaticResource MsgVis}}">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#15803D" FontSize="13"/>
            </Border>

            <!-- Account Info -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Account" Style="{StaticResource HeadingMedium}"
                               FontSize="15" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="NAME" Style="{StaticResource SecondaryText}"
                                       FontSize="10" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding CurrentUserName}" Style="{StaticResource BodyText}"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="ROLE" Style="{StaticResource SecondaryText}"
                                       FontSize="10" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding CurrentUserRole}" Style="{StaticResource BodyText}"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="ORGANISATION" Style="{StaticResource SecondaryText}"
                                       FontSize="10" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding CurrentOrgName}" Style="{StaticResource BodyText}"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>

                    <Separator Margin="0,16,0,16" Background="{StaticResource BorderBrush}"/>

                    <!-- Run on Windows Startup -->
                    <StackPanel Orientation="Horizontal">
                        <CheckBox Content="Run EAMAS on Windows startup (monitoring continues in background)"
                                  IsChecked="{Binding RunOnStartup}"
                                  Style="{StaticResource StyledCheckBox}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Change Password (all roles) -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Change Password" Style="{StaticResource HeadingMedium}"
                               FontSize="15" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="CURRENT PASSWORD" Style="{StaticResource SecondaryText}"
                                       FontSize="10" Margin="0,0,0,6"/>
                            <PasswordBox x:Name="TxtCurrentPwd" Style="{StaticResource PasswordField}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4,0">
                            <TextBlock Text="NEW PASSWORD" Style="{StaticResource SecondaryText}"
                                       FontSize="10" Margin="0,0,0,6"/>
                            <PasswordBox x:Name="TxtNewPwd" Style="{StaticResource PasswordField}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="8,0,0,0">
                            <TextBlock Text="CONFIRM PASSWORD" Style="{StaticResource SecondaryText}"
                                       FontSize="10" Margin="0,0,0,6"/>
                            <PasswordBox x:Name="TxtConfirmPwd" Style="{StaticResource PasswordField}"/>
                        </StackPanel>
                    </Grid>
                    <Button Content="Change Password" Style="{StaticResource SecondaryButton}"
                            HorizontalAlignment="Left" Margin="0,12,0,0"
                            Click="ChangePassword_Click"/>
                </StackPanel>
            </Border>

            <!-- Monitoring Settings (Admin/Manager only) -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16"
                    IsEnabled="{Binding IsAdmin}"
                    Visibility="{Binding IsEmployee, Converter={StaticResource BoolVisInverse}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="Monitoring" Style="{StaticResource HeadingMedium}" FontSize="15"/>
                        <Border Background="#FEF3C7" CornerRadius="4" Padding="6,2" Margin="12,0,0,0">
                            <TextBlock Text="Admin only" Foreground="#92400E" FontSize="10"/>
                        </Border>
                    </StackPanel>

                    <CheckBox Content="Enable activity monitoring" IsChecked="{Binding MonitoringEnabled}"
                              Style="{StaticResource StyledCheckBox}" Margin="0,0,0,12"/>
                    <CheckBox Content="Enable screenshot capture" IsChecked="{Binding ScreenshotsEnabled}"
                              Style="{StaticResource StyledCheckBox}" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="SCREENSHOT INTERVAL (min)" Style="{StaticResource SecondaryText}"
                                       FontSize="10" Margin="0,0,0,6"/>
                            <TextBox Style="{StaticResource InputField}"
                                     Text="{Binding ScreenshotInterval, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4,0">
                            <TextBlock Text="IDLE THRESHOLD (min)" Style="{StaticResource SecondaryText}"
                                       FontSize="10" Margin="0,0,0,6"/>
                            <TextBox Style="{StaticResource InputField}"
                                     Text="{Binding IdleThreshold, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="8,0,0,0">
                            <TextBlock Text="SCREENSHOT QUALITY (1-100)" Style="{StaticResource SecondaryText}"
                                       FontSize="10" Margin="0,0,0,6"/>
                            <TextBox Style="{StaticResource InputField}"
                                     Text="{Binding JpegQuality, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Alerts Settings (Admin only) -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16"
                    IsEnabled="{Binding IsAdmin}"
                    Visibility="{Binding IsEmployee, Converter={StaticResource BoolVisInverse}}">
                <StackPanel>
                    <TextBlock Text="Alerts" Style="{StaticResource HeadingMedium}"
                               FontSize="15" Margin="0,0,0,16"/>

                    <CheckBox Content="Alert when employee is idle too long"
                              IsChecked="{Binding AlertOnLongIdle}"
                              Style="{StaticResource StyledCheckBox}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="20,0,0,16">
                        <TextBlock Text="Idle threshold:" Style="{StaticResource SecondaryText}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Style="{StaticResource InputField}" Width="60"
                                 Text="{Binding LongIdleThreshold, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text=" minutes" Style="{StaticResource SecondaryText}"
                                   VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>

                    <CheckBox Content="Alert when distracting usage exceeds threshold"
                              IsChecked="{Binding AlertOnDistracting}"
                              Style="{StaticResource StyledCheckBox}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                        <TextBlock Text="Threshold:" Style="{StaticResource SecondaryText}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Style="{StaticResource InputField}" Width="60"
                                 Text="{Binding DistractingThreshold, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text=" minutes per day" Style="{StaticResource SecondaryText}"
                                   VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Storage / Retention (Admin only) -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16"
                    IsEnabled="{Binding IsAdmin}"
                    Visibility="{Binding IsEmployee, Converter={StaticResource BoolVisInverse}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="Storage" Style="{StaticResource HeadingMedium}" FontSize="15"/>
                    </StackPanel>
                    <TextBlock Style="{StaticResource SecondaryText}" FontSize="12" Margin="0,0,0,12"
                               TextWrapping="Wrap"
                               Text="Screenshots are stored in MongoDB (GridFS). Set the maximum retention period below."/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="MAX SCREENSHOT AGE (days)" Style="{StaticResource SecondaryText}"
                                   FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBox Style="{StaticResource InputField}" Width="80"
                                 Text="{Binding MaxScreenshotAge, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Save Button (Admin only) -->
            <Button Content="Save All Settings" Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveSettingsCommand}"
                    Width="180" HorizontalAlignment="Left"
                    Visibility="{Binding IsAdmin, Converter={StaticResource BoolVis}}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
