<Window x:Class="EAMAS.Desktop.Views.ConnectionSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EAMAS - Database Setup" Height="480" Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F8FAFC">

    <Grid Margin="36">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Border Width="40" Height="40" CornerRadius="8"
                    Background="{StaticResource PrimaryBrush}"
                    VerticalAlignment="Center" Margin="0,0,12,0">
                <TextBlock Text="E" FontSize="20" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Database Setup" FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="Connect EAMAS to your MongoDB instance"
                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </StackPanel>

        <TextBlock Grid.Row="1" Text="MONGODB CONNECTION STRING" FontSize="10" FontWeight="SemiBold"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
        <TextBox Grid.Row="2" x:Name="TxtConnectionString"
                 Style="{StaticResource InputField}"
                 TextWrapping="Wrap" AcceptsReturn="False"
                 Height="72" VerticalContentAlignment="Top"
                 ToolTip="Paste your MongoDB connection string here"
                 Margin="0,0,0,4"/>
        <TextBlock Grid.Row="3"
                   Text="Example: mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&amp;w=majority"
                   FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,16"/>

        <StackPanel Grid.Row="4" Margin="0,0,0,16">
            <TextBlock Text="DATABASE NAME" FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtDatabaseName"
                     Style="{StaticResource InputField}"
                     Text="eamas"/>
        </StackPanel>

        <TextBlock Grid.Row="5" x:Name="TxtStatus"
                   Foreground="{StaticResource ErrorBrush}"
                   FontSize="12" TextWrapping="Wrap"
                   VerticalAlignment="Top" Margin="0,0,0,8"
                   Visibility="Collapsed"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnTest" Content="Test Connection"
                    Style="{StaticResource SecondaryButton}"
                    Width="140" Height="36"
                    Click="TestConnection_Click"
                    Margin="0,0,10,0"/>
            <Button x:Name="BtnSave" Content="Save &amp; Connect"
                    Style="{StaticResource PrimaryButton}"
                    Width="140" Height="36"
                    Click="SaveConnection_Click"/>
        </StackPanel>
    </Grid>
</Window>
