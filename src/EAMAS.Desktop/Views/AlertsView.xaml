<UserControl x:Class="EAMAS.Desktop.Views.AlertsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:EAMAS.Desktop.Converters"
             Background="{StaticResource ContentBgBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVisInverse" Invert="True"/>
        <conv:NullToVisibilityConverter x:Key="NullVis"/>
        <conv:BoolToHighlightBrushConverter x:Key="UnreadBrush"/>
    </UserControl.Resources>

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Alerts" Style="{StaticResource HeadingLarge}"/>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Style="{StaticResource SecondaryText}">
                        <Run Text="{Binding UnreadCount, Mode=OneWay}"/>
                        <Run Text=" unread"/>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <!-- Unread filter — only for non-SuperAdmin (SuperAdmin always sees all) -->
                <CheckBox Content="Unread only" IsChecked="{Binding ShowUnreadOnly}"
                          VerticalAlignment="Center" Margin="0,0,16,0"
                          Style="{StaticResource StyledCheckBox}"
                          Visibility="{Binding IsSuperAdmin, Converter={StaticResource BoolVisInverse}}"/>
                <Button Content="&#xE8FB;  Mark All Read" Style="{StaticResource SecondaryButton}"
                        Command="{Binding MarkAllReadCommand}" Margin="0,0,8,0"/>
                <Button Content="&#xE72C;  Refresh" Style="{StaticResource SecondaryButton}"
                        Command="{Binding LoadCommand}"/>
            </StackPanel>
        </Grid>

        <!-- Loading bar -->
        <ProgressBar Grid.Row="1" IsIndeterminate="True" Height="3"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolVis}}"
                     Margin="0,0,0,8"/>

        <!-- Alerts list -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Alerts}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="20,14"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Background="{Binding IsRead,
                                        Converter={StaticResource UnreadBrush},
                                        ConverterParameter=invert}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRead}" Value="False">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="#F0F5FF"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Type badge -->
                                    <Border Grid.Column="0" CornerRadius="4" Padding="8,3"
                                            Margin="0,0,14,0" VerticalAlignment="Top"
                                            Background="{Binding TypeColor}">
                                        <TextBlock Text="{Binding TypeLabel}" FontSize="10"
                                                   FontWeight="SemiBold" Foreground="White"/>
                                    </Border>

                                    <!-- Message + time -->
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Message}"
                                                   Style="{StaticResource BodyText}"
                                                   TextWrapping="Wrap" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding TimeLabel}"
                                                   Style="{StaticResource SecondaryText}"
                                                   FontSize="11"/>
                                    </StackPanel>

                                    <!-- Unread indicator dot -->
                                    <Ellipse Grid.Column="2" Width="8" Height="8"
                                             Fill="{StaticResource PrimaryBrush}"
                                             VerticalAlignment="Center" Margin="12,0,0,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRead}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
