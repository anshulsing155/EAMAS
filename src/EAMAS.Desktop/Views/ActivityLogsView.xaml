<UserControl x:Class="EAMAS.Desktop.Views.ActivityLogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:EAMAS.Desktop.Converters"
             xmlns:local="clr-namespace:EAMAS.Desktop.Views"
             Background="{StaticResource ContentBgBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVisInverse" Invert="True"/>
        <local:CategoryBgColorConverter x:Key="CatBgColorConv"/>
        <local:CategoryTextColorConverter x:Key="CatTextColorConv"/>
    </UserControl.Resources>

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Activity Logs" Style="{StaticResource HeadingLarge}"/>
            <TextBlock Text="Detailed application and window tracking" Style="{StaticResource SecondaryText}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="16,12" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="&#x276E;" Style="{StaticResource SecondaryButton}"
                        Command="{Binding PreviousDayCommand}" Width="36" Padding="0"/>
                <DatePicker Grid.Column="1" SelectedDate="{Binding SelectedDate}"
                            Margin="4,0" FontSize="13" Width="130"/>
                <Button Grid.Column="2" Content="&#x276F;" Style="{StaticResource SecondaryButton}"
                        Command="{Binding NextDayCommand}" Width="36" Padding="0" Margin="0,0,8,0"/>

                <!-- Org selector (SuperAdmin only) -->
                <ComboBox Grid.Column="3" Style="{StaticResource StyledComboBox}"
                          ItemsSource="{Binding Organizations}"
                          SelectedItem="{Binding SelectedOrg}"
                          DisplayMemberPath="Name"
                          Width="160" HorizontalAlignment="Left" Margin="0,0,8,0"
                          Visibility="{Binding ShowOrgSelector, Converter={StaticResource BoolVis}}"/>

                <!-- User selector (manager and above) -->
                <ComboBox Grid.Column="3" Style="{StaticResource StyledComboBox}"
                          ItemsSource="{Binding Users}"
                          SelectedItem="{Binding SelectedUser}"
                          DisplayMemberPath="FullName"
                          Width="160" HorizontalAlignment="Left" Margin="0,0,8,0"
                          Visibility="{Binding ShowUserSelector, Converter={StaticResource BoolVis}}"/>

                <!-- Filter -->
                <TextBox Grid.Column="4" Style="{StaticResource InputField}"
                         Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,8,0">
                    <TextBox.Resources>
                        <Style TargetType="TextBox" BasedOn="{StaticResource InputField}">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="Search app or title..." Foreground="#94A3B8"
                                                               Margin="10,8" FontSize="13"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <Button Grid.Column="5" Content="Today" Style="{StaticResource SecondaryButton}"
                        Command="{Binding TodayCommand}"/>
            </Grid>
        </Border>

        <!-- ── Day Timeline ───────────────────────────────────────────────────── -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="16,12" Margin="0,0,0,16">
            <StackPanel>
                <!-- Hour labels -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"  Text="07:00" Style="{StaticResource SecondaryText}" FontSize="9"/>
                    <TextBlock Grid.Column="1"  Text="08:00" Style="{StaticResource SecondaryText}" FontSize="9"/>
                    <TextBlock Grid.Column="2"  Text="09:00" Style="{StaticResource SecondaryText}" FontSize="9"/>
                    <TextBlock Grid.Column="3"  Text="10:00" Style="{StaticResource SecondaryText}" FontSize="9"/>
                    <TextBlock Grid.Column="4"  Text="11:00" Style="{StaticResource SecondaryText}" FontSize="9"/>
                    <TextBlock Grid.Column="5"  Text="12:00" Style="{StaticResource SecondaryText}" FontSize="9"/>
                    <TextBlock Grid.Column="6"  Text="13:00" Style="{StaticResource SecondaryText}" FontSize="9"/>
                    <TextBlock Grid.Column="7"  Text="14:00" Style="{StaticResource SecondaryText}" FontSize="9"/>
                    <TextBlock Grid.Column="8"  Text="15:00" Style="{StaticResource SecondaryText}" FontSize="9"/>
                    <TextBlock Grid.Column="9"  Text="16:00" Style="{StaticResource SecondaryText}" FontSize="9"/>
                    <TextBlock Grid.Column="10" Text="17:00" Style="{StaticResource SecondaryText}" FontSize="9"/>
                    <TextBlock Grid.Column="11" Text="18:00" Style="{StaticResource SecondaryText}" FontSize="9"/>
                    <TextBlock Grid.Column="12" Text="19:00" Style="{StaticResource SecondaryText}" FontSize="9"/>
                    <TextBlock Grid.Column="13" Text="20:00" Style="{StaticResource SecondaryText}" FontSize="9"/>
                    <TextBlock Grid.Column="14" Text="21:00" Style="{StaticResource SecondaryText}" FontSize="9" HorizontalAlignment="Right"/>
                </Grid>

                <!-- Timeline canvas (840 logical units = 14 hours × 60 min) -->
                <Border CornerRadius="4" Background="#F1F5F9" Height="36" ClipToBounds="True">
                    <Viewbox Stretch="Fill" StretchDirection="Both">
                        <Canvas Width="840" Height="36">
                            <!-- Hour guide lines -->
                            <Rectangle Canvas.Left="60"  Width="1" Height="36" Fill="#CBD5E1" Opacity="0.5"/>
                            <Rectangle Canvas.Left="120" Width="1" Height="36" Fill="#CBD5E1" Opacity="0.5"/>
                            <Rectangle Canvas.Left="180" Width="1" Height="36" Fill="#CBD5E1" Opacity="0.5"/>
                            <Rectangle Canvas.Left="240" Width="1" Height="36" Fill="#CBD5E1" Opacity="0.5"/>
                            <Rectangle Canvas.Left="300" Width="1" Height="36" Fill="#CBD5E1" Opacity="0.5"/>
                            <Rectangle Canvas.Left="360" Width="1" Height="36" Fill="#CBD5E1" Opacity="0.5"/>
                            <Rectangle Canvas.Left="420" Width="1" Height="36" Fill="#CBD5E1" Opacity="0.5"/>
                            <Rectangle Canvas.Left="480" Width="1" Height="36" Fill="#CBD5E1" Opacity="0.5"/>
                            <Rectangle Canvas.Left="540" Width="1" Height="36" Fill="#CBD5E1" Opacity="0.5"/>
                            <Rectangle Canvas.Left="600" Width="1" Height="36" Fill="#CBD5E1" Opacity="0.5"/>
                            <Rectangle Canvas.Left="660" Width="1" Height="36" Fill="#CBD5E1" Opacity="0.5"/>
                            <Rectangle Canvas.Left="720" Width="1" Height="36" Fill="#CBD5E1" Opacity="0.5"/>
                            <Rectangle Canvas.Left="780" Width="1" Height="36" Fill="#CBD5E1" Opacity="0.5"/>

                            <!-- Activity segments via ItemsControl -->
                            <ItemsControl ItemsSource="{Binding TimelineSegments}" Width="840" Height="36">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="840" Height="36"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style>
                                        <Setter Property="Canvas.Left" Value="{Binding LeftMin}"/>
                                        <Setter Property="Canvas.Top"  Value="2"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Rectangle Width="{Binding WidthMin}" Height="32"
                                                   RadiusX="2" RadiusY="2"
                                                   Fill="{Binding Fill}"
                                                   ToolTip="{Binding Tooltip}"
                                                   Opacity="0.88"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Canvas>
                    </Viewbox>
                </Border>

                <!-- Legend -->
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Rectangle Width="12" Height="12" RadiusX="2" RadiusY="2" Fill="#16A34A" Margin="0,0,4,0"/>
                    <TextBlock Text="Productive" Style="{StaticResource SecondaryText}" FontSize="10" Margin="0,0,12,0"/>
                    <Rectangle Width="12" Height="12" RadiusX="2" RadiusY="2" Fill="#3B82F6" Margin="0,0,4,0"/>
                    <TextBlock Text="Neutral" Style="{StaticResource SecondaryText}" FontSize="10" Margin="0,0,12,0"/>
                    <Rectangle Width="12" Height="12" RadiusX="2" RadiusY="2" Fill="#EF4444" Margin="0,0,4,0"/>
                    <TextBlock Text="Distracting" Style="{StaticResource SecondaryText}" FontSize="10" Margin="0,0,12,0"/>
                    <Rectangle Width="12" Height="12" RadiusX="2" RadiusY="2" Fill="#94A3B8" Margin="0,0,4,0"/>
                    <TextBlock Text="Idle" Style="{StaticResource SecondaryText}" FontSize="10"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Data Grid -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0">
            <DataGrid Style="{StaticResource StyledDataGrid}"
                      ItemsSource="{Binding Logs}"
                      VirtualizingPanel.IsVirtualizing="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="TIME" Binding="{Binding Time}" Width="80"/>
                    <DataGridTextColumn Header="APPLICATION" Binding="{Binding AppName}" Width="160"/>
                    <DataGridTextColumn Header="WINDOW TITLE" Binding="{Binding WindowTitle}" Width="*"/>
                    <DataGridTextColumn Header="DURATION" Binding="{Binding Duration}" Width="80"/>
                    <DataGridTemplateColumn Header="CATEGORY" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="6,2" Margin="4,2"
                                        HorizontalAlignment="Left">
                                    <Border.Background>
                                        <SolidColorBrush Color="{Binding Category,
                                            Converter={StaticResource CatBgColorConv}}"/>
                                    </Border.Background>
                                    <TextBlock Text="{Binding CategoryLabel}" FontSize="11"
                                               FontWeight="SemiBold">
                                        <TextBlock.Foreground>
                                            <SolidColorBrush Color="{Binding Category,
                                                Converter={StaticResource CatTextColorConv}}"/>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer -->
        <TextBlock Grid.Row="4" Margin="0,8,0,0" Style="{StaticResource SecondaryText}">
            <Run Text="{Binding TotalRecords, Mode=OneWay}"/>
            <Run Text=" records"/>
        </TextBlock>
    </Grid>
</UserControl>
