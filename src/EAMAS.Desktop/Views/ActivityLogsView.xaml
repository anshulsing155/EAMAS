<UserControl x:Class="EAMAS.Desktop.Views.ActivityLogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:EAMAS.Desktop.Converters"
             xmlns:local="clr-namespace:EAMAS.Desktop.Views"
             Background="{StaticResource ContentBgBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVisInverse" Invert="True"/>
        <local:CategoryBgColorConverter x:Key="CatBgColorConv"/>
        <local:CategoryTextColorConverter x:Key="CatTextColorConv"/>
    </UserControl.Resources>

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Activity Logs" Style="{StaticResource HeadingLarge}"/>
            <TextBlock Text="Detailed application and window tracking" Style="{StaticResource SecondaryText}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="16,12" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="&#x276E;" Style="{StaticResource SecondaryButton}"
                        Command="{Binding PreviousDayCommand}" Width="36" Padding="0"/>
                <DatePicker Grid.Column="1" SelectedDate="{Binding SelectedDate}"
                            Margin="4,0" FontSize="13" Width="130"/>
                <Button Grid.Column="2" Content="&#x276F;" Style="{StaticResource SecondaryButton}"
                        Command="{Binding NextDayCommand}" Width="36" Padding="0" Margin="0,0,8,0"/>

                <!-- Org selector (SuperAdmin only) -->
                <ComboBox Grid.Column="3" Style="{StaticResource StyledComboBox}"
                          ItemsSource="{Binding Organizations}"
                          SelectedItem="{Binding SelectedOrg}"
                          DisplayMemberPath="Name"
                          Width="160" HorizontalAlignment="Left" Margin="0,0,8,0"
                          Visibility="{Binding ShowOrgSelector, Converter={StaticResource BoolVis}}"/>

                <!-- User selector (manager and above) -->
                <ComboBox Grid.Column="3" Style="{StaticResource StyledComboBox}"
                          ItemsSource="{Binding Users}"
                          SelectedItem="{Binding SelectedUser}"
                          DisplayMemberPath="FullName"
                          Width="160" HorizontalAlignment="Left" Margin="0,0,8,0"
                          Visibility="{Binding ShowUserSelector, Converter={StaticResource BoolVis}}"/>

                <!-- Filter -->
                <TextBox Grid.Column="4" Style="{StaticResource InputField}"
                         Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,8,0">
                    <TextBox.Resources>
                        <Style TargetType="TextBox" BasedOn="{StaticResource InputField}">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="Search app or title..." Foreground="#94A3B8"
                                                               Margin="10,8" FontSize="13"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <Button Grid.Column="5" Content="Today" Style="{StaticResource SecondaryButton}"
                        Command="{Binding TodayCommand}"/>
            </Grid>
        </Border>

        <!-- Data Grid -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <DataGrid Style="{StaticResource StyledDataGrid}"
                      ItemsSource="{Binding Logs}"
                      VirtualizingPanel.IsVirtualizing="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="TIME" Binding="{Binding Time}" Width="80"/>
                    <DataGridTextColumn Header="APPLICATION" Binding="{Binding AppName}" Width="160"/>
                    <DataGridTextColumn Header="WINDOW TITLE" Binding="{Binding WindowTitle}" Width="*"/>
                    <DataGridTextColumn Header="DURATION" Binding="{Binding Duration}" Width="80"/>
                    <DataGridTemplateColumn Header="CATEGORY" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="6,2" Margin="4,2"
                                        HorizontalAlignment="Left">
                                    <Border.Background>
                                        <SolidColorBrush Color="{Binding Category,
                                            Converter={StaticResource CatBgColorConv}}"/>
                                    </Border.Background>
                                    <TextBlock Text="{Binding CategoryLabel}" FontSize="11"
                                               FontWeight="SemiBold">
                                        <TextBlock.Foreground>
                                            <SolidColorBrush Color="{Binding Category,
                                                Converter={StaticResource CatTextColorConv}}"/>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer -->
        <TextBlock Grid.Row="3" Margin="0,8,0,0" Style="{StaticResource SecondaryText}">
            <Run Text="{Binding TotalRecords, Mode=OneWay}"/>
            <Run Text=" records"/>
        </TextBlock>
    </Grid>
</UserControl>
