<UserControl x:Class="EAMAS.Desktop.Views.SprintPlannerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:EAMAS.Desktop.Converters"
             Background="{StaticResource ContentBgBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVisInv" Invert="True"/>
        <conv:IntToVisibilityConverter x:Key="IntVis"/>
        <conv:SprintStatusToColorConverter x:Key="SprintStatusColor"/>
        <conv:StatusMessageColorConverter x:Key="StatusMsgColor"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24">

            <!-- Header -->
            <Grid Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Sprint Planner" Style="{StaticResource HeadingLarge}"/>
                    <TextBlock Text="AI-powered sprint planning and velocity tracking"
                               Style="{StaticResource SecondaryText}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <ComboBox ItemsSource="{Binding Projects}" SelectedItem="{Binding SelectedProject}"
                              DisplayMemberPath="Name" Style="{StaticResource ModernComboBox}"
                              Width="180" Margin="0,0,10,0"/>
                </StackPanel>
            </Grid>

            <!-- Status (dynamic color) -->
            <Border CornerRadius="8" Padding="14,8" Margin="0,0,0,8"
                    Background="{Binding StatusMessage, Converter={StaticResource StatusMsgColor}}"
                    Visibility="{Binding StatusMessage, Converter={StaticResource BoolVis}}">
                <Grid>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontSize="13"/>
                    <ProgressBar IsIndeterminate="True" Height="2" VerticalAlignment="Bottom"
                                 Foreground="#60A5FA" Background="Transparent"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}"/>
                </Grid>
            </Border>

            <!-- Action Row -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="🤖 AI Plan Sprint" Style="{StaticResource PrimaryButton}"
                        Command="{Binding PlanWithAiCommand}" Margin="0,0,8,0" Height="40"/>
                <Button Grid.Column="1" Content="✓ Create Sprint" Style="{StaticResource SecondaryButton}"
                        Command="{Binding CreateSprintCommand}" Margin="0,0,8,0" Height="40"/>
                <Button Grid.Column="2" Content="▶ Activate Sprint" Style="{StaticResource SecondaryButton}"
                        Command="{Binding ActivateSprintCommand}" Margin="0,0,8,0" Height="40"/>
                <Button Grid.Column="3" Content="✔ Complete Sprint" Style="{StaticResource SecondaryButton}"
                        Command="{Binding CompleteSprintCommand}" Height="40"/>
            </Grid>

            <!-- Sprint Goal + Dates -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,20"
                    Visibility="{Binding ProposedTasks.Count, Converter={StaticResource IntVis}}">
                <StackPanel>
                    <TextBlock Text="Sprint Goal" Style="{StaticResource FieldLabel}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding SprintGoal, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}" FontSize="14"
                             FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Start Date" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                            <DatePicker SelectedDate="{Binding StartDate}" Style="{StaticResource ModernDatePicker}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="End Date" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                            <DatePicker SelectedDate="{Binding EndDate}" Style="{StaticResource ModernDatePicker}"/>
                        </StackPanel>
                    </Grid>
                    <!-- Date validation warning -->
                    <Border CornerRadius="6" Margin="0,10,0,0" Padding="12,8"
                            Background="#78350F"
                            Visibility="{Binding IsDateInvalid, Converter={StaticResource BoolVis}}">
                        <TextBlock Text="&#x26A0;  End date must be after start date." Foreground="#FCD34D" FontSize="12"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Two-column: Backlog + Proposed -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Backlog -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                            <TextBlock Text="Backlog" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock HorizontalAlignment="Right" Foreground="#64748B" FontSize="12"
                                       Text="{Binding BacklogTasks.Count, StringFormat='{}{0} tasks'}"/>
                        </Grid>
                        <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding BacklogTasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#0F172A" CornerRadius="6" Padding="10,8" Margin="0,0,0,6"
                                                BorderBrush="#1E293B" BorderThickness="1">
                                            <Grid>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontSize="12"
                                                               Foreground="White" TextWrapping="Wrap"
                                                               MaxHeight="34" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Foreground="#64748B" FontSize="11" Margin="0,2,0,0">
                                                        <Run Text="{Binding Priority}"/>
                                                        <Run Text=" · "/>
                                                        <Run Text="{Binding EstimatedHours, StringFormat='{}{0:0.#}h'}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <Button Content="+" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                        Width="24" Height="24" FontSize="14"
                                                        Background="#1E3A5F" Foreground="#60A5FA"
                                                        BorderThickness="0"
                                                        Command="{Binding DataContext.AddToSprintCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}" Cursor="Hand"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- Proposed Sprint Tasks -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                            <TextBlock Text="Sprint Tasks" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                <TextBlock Foreground="#64748B" FontSize="12"
                                           Text="{Binding ProposedTasks.Count, StringFormat='{}{0} tasks'}"/>
                            </StackPanel>
                        </Grid>
                        <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ProposedTasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1E3A5F" CornerRadius="6" Padding="10,8" Margin="0,0,0,6"
                                                BorderBrush="#2563EB" BorderThickness="1">
                                            <Grid>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontSize="12"
                                                               Foreground="White" TextWrapping="Wrap"
                                                               MaxHeight="34" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Foreground="#93C5FD" FontSize="11" Margin="0,2,0,0">
                                                        <Run Text="{Binding Priority}"/>
                                                        <Run Text=" · "/>
                                                        <Run Text="{Binding EstimatedHours, StringFormat='{}{0:0.#}h'}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <Button Content="−" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                        Width="24" Height="24" FontSize="14"
                                                        Background="#7F1D1D" Foreground="#FCA5A5"
                                                        BorderThickness="0"
                                                        Command="{Binding DataContext.RemoveFromSprintCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}" Cursor="Hand"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Sprint History -->
            <TextBlock Text="Sprint History" FontSize="14" FontWeight="SemiBold" Foreground="White"
                       Margin="0,24,0,12"
                       Visibility="{Binding Sprints.Count, Converter={StaticResource IntVis}}"/>
            <ItemsControl ItemsSource="{Binding Sprints}"
                          Visibility="{Binding Sprints.Count, Converter={StaticResource IntVis}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                            <StackPanel>
                                <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="White" Margin="0,0,10,0"/>
                                        <Border CornerRadius="4" Padding="6,2"
                                                Background="{Binding Status, Converter={StaticResource SprintStatusColor}}">
                                            <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Goal}" Foreground="#94A3B8" FontSize="12"
                                               Margin="0,4,0,2" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Foreground="#64748B" FontSize="11">
                                        <Run Text="{Binding StartDate, StringFormat='{}{0:MMM d}'}"/>
                                        <Run Text=" – "/>
                                        <Run Text="{Binding EndDate, StringFormat='{}{0:MMM d, yyyy}'}"/>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock Foreground="#94A3B8" FontSize="12" HorizontalAlignment="Right">
                                        <Run Text="Planned: "/>
                                        <Run Text="{Binding PlannedVelocity, StringFormat='{}{0:0}h'}"/>
                                    </TextBlock>
                                    <TextBlock Foreground="#22C55E" FontSize="12" HorizontalAlignment="Right"
                                               Visibility="{Binding ActualVelocity, Converter={StaticResource IntVis}}">
                                        <Run Text="Done: "/>
                                        <Run Text="{Binding ActualVelocity, StringFormat='{}{0:0}h'}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                            
                            <!-- AI Retrospective -->
                            <Border Background="#1E293B" CornerRadius="6" Padding="10,8" Margin="0,12,0,0"
                                    Visibility="{Binding Retrospective, Converter={StaticResource BoolVis}}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="&#xE90A;" FontFamily="Segoe MDL2 Assets" Foreground="#60A5FA" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="AI Retrospective" Foreground="#60A5FA" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Retrospective}" Foreground="#CBD5E1" FontSize="12" TextWrapping="Wrap" LineHeight="18"/>
                                </StackPanel>
                            </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
