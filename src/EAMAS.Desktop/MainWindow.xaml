<Window x:Class="EAMAS.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:EAMAS.Desktop.Converters"
        xmlns:services="clr-namespace:EAMAS.Desktop.Services"
        Title="EAMAS — Employee Activity Monitoring &amp; Analytics"
        Height="760" Width="1200" MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ContentBgBrush}">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:IntToVisibilityConverter x:Key="IntVis"/>
        <conv:InitialsConverter x:Key="InitialsConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== Sidebar ===== -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBgBrush}">
            <DockPanel>
                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="20,24,20,8">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Border Width="34" Height="34" CornerRadius="8"
                                Background="{StaticResource PrimaryBrush}">
                            <TextBlock Text="E" FontSize="18" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="EAMAS" FontSize="15" FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="Activity Monitor" FontSize="10"
                                       Foreground="#64748B"/>
                        </StackPanel>
                    </StackPanel>
                    <Separator Background="#1E293B" Margin="0,16,0,8"/>
                </StackPanel>

                <!-- Bottom: user info + logout -->
                <StackPanel DockPanel.Dock="Bottom" Margin="16,0,16,16">
                    <Separator Background="#1E293B" Margin="0,0,0,12"/>

                    <!-- Current activity -->
                    <Border Background="#1E293B" CornerRadius="6" Padding="10,8" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="NOW TRACKING" FontSize="9" FontWeight="SemiBold"
                                       Foreground="#475569" Margin="0,0,0,3"/>
                            <TextBlock Text="{Binding CurrentActivity}" FontSize="11"
                                       Foreground="#94A3B8" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>

                    <!-- User info -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Width="32" Height="32" CornerRadius="16"
                                Background="{StaticResource PrimaryBrush}">
                            <TextBlock FontSize="13" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Text="{Binding CurrentUser.FullName,
                                           Converter={StaticResource InitialsConverter}}"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentUser.FullName}"
                                       FontSize="12" FontWeight="SemiBold" Foreground="White"
                                       MaxWidth="130" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding CurrentUser.Role}"
                                       FontSize="10" Foreground="#64748B"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Content="⏻  Logout" Style="{StaticResource NavButton}"
                            Command="{Binding LogoutCommand}"
                            Foreground="#EF4444" HorizontalContentAlignment="Center"/>
                </StackPanel>

                <!-- Nav Items -->
                <StackPanel Margin="12,0">
                    <Button x:Name="BtnDashboard"
                            Command="{Binding NavigateDashboardCommand}"
                            Style="{StaticResource NavButton}" Margin="0,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="15" Width="22"/>
                            <TextBlock Text="Dashboard" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnActivity"
                            Command="{Binding NavigateActivityCommand}"
                            Style="{StaticResource NavButton}" Margin="0,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="15" Width="22"/>
                            <TextBlock Text="Activity Logs" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnScreenshots"
                            Command="{Binding NavigateScreenshotsCommand}"
                            Style="{StaticResource NavButton}" Margin="0,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="15" Width="22"/>
                            <TextBlock Text="Screenshots" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnReports"
                            Command="{Binding NavigateReportsCommand}"
                            Style="{StaticResource NavButton}" Margin="0,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="15" Width="22"/>
                            <TextBlock Text="Reports" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Employees (admin/manager only) -->
                    <Button x:Name="BtnEmployees"
                            Command="{Binding NavigateEmployeesCommand}"
                            Style="{StaticResource NavButton}" Margin="0,2"
                            Visibility="{Binding IsManager, Converter={StaticResource BoolVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="15" Width="22"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Employees" Margin="8,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <!-- Alert indicator -->
                    <Button x:Name="BtnAlerts"
                            Style="{StaticResource NavButton}" Margin="0,2"
                            IsEnabled="False">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xEA8F;" FontFamily="Segoe MDL2 Assets" FontSize="15" Width="22"/>
                            <TextBlock Text="Alerts" Margin="8,0,0,0"/>
                            <Border Background="#EF4444" CornerRadius="10" Padding="6,1"
                                    Margin="8,0,0,0"
                                    Visibility="{Binding UnreadAlerts, Converter={StaticResource IntVis}}">
                                <TextBlock Text="{Binding UnreadAlerts}" FontSize="10"
                                           Foreground="White" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnSettings"
                            Command="{Binding NavigateSettingsCommand}"
                            Style="{StaticResource NavButton}" Margin="0,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="15" Width="22"/>
                            <TextBlock Text="Settings" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===== Content Area ===== -->
        <ContentControl x:Name="MainContent" Grid.Column="1"
                        Background="{StaticResource ContentBgBrush}"/>
    </Grid>
</Window>
